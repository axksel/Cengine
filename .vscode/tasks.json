{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build WASM",
      "type": "shell",
      "command": "emcmake cmake -B build -G Ninja; cmake --build build",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Serve",
      "type": "shell",
      "command": "python -m http.server 8080 --directory build",
      "group": "test"
    }
  ]
}